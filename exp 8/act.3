try:
    bill = float(input("Enter total bill: "))
    people = int(input("Enter number of people: "))
    result = bill / people
    print("Each person pays:", result)
except ZeroDivisionError:
    print("Cannot divide by zero people!")
except ValueError:
    print("Invalid input!")
