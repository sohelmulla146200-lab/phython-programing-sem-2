class Employee:
    def __init__(self, name, emp_id, basic_salary):   # <-- FIX HERE
        self.name = name
        self.emp_id = emp_id
        self.basic_salary = basic_salary

    def calculate_gross_salary(self):
        hra = 0.2 * self.basic_salary
        da = 0.1 * self.basic_salary
        return self.basic_salary + hra + da

    def display_details(self):
        print("Employee Name:", self.name)
        print("Employee ID:", self.emp_id)
        print("Basic Salary:", self.basic_salary)
        print("Gross Salary:", self.calculate_gross_salary())


# Main program
name = input("Enter employee name: ")
emp_id = input("Enter employee ID: ")
basic_salary = float(input("Enter basic salary: "))

emp = Employee(name, emp_id, basic_salary)

print("\nEmployee Details:")
emp.display_details()
